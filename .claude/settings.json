{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/update-section-map.sh 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}